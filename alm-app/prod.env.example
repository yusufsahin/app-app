# Copy to .env next to docker-compose.prod.yml (do not commit .env)
ALM_POSTGRES_USER=alm
ALM_POSTGRES_PASSWORD=change-me
ALM_POSTGRES_DB=alm
ALM_JWT_SECRET_KEY=change-me-long-random

# Harici nginx: TLS bu sunucuda; ALM yalnızca localhost
ALM_FRONTEND_PORT_MAPPING=127.0.0.1:9081:80

# JSON dizi (pydantic-settings)
ALM_CORS_ORIGINS=["https://demo.pamera.app.provera.net.tr"]
ALM_BASE_URL=https://demo.pamera.app.provera.net.tr

# false = üretim: privilege + şablon seed her açılışta çalışır; demo tenant oluşturulmaz.
# true + ALM_ENVIRONMENT≠production → boş DB’de demo (DEPLOY.md).
ALM_SEED_DEMO_DATA=false
